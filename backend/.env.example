# Конфигурация базы данных PostgreSQL
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/telegram_bots_tickets

# JWT секретные ключи (сгенерируйте случайные строки минимум 32 символа)
# Для генерации: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_random_secret_key_for_access_token_here_min_32_chars
JWT_REFRESH_SECRET=your_random_secret_key_for_refresh_token_here_min_32_chars

# Порт сервера
PORT=3000

# URL frontend (для CORS)
# Для продакшена используйте домен вашего фронтенда
# Можно указать несколько доменов через запятую, но в этом примере показан основной
FRONTEND_URL=https://telegram-bots.pl

# Telegram Bot настройки
# Получить токен: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Chat ID админов (через @userinfobot)
# Разделитель - запятая для нескольких админов
TELEGRAM_ADMIN_CHAT_IDS=123456789,987654321

# URL для ссылок в уведомлениях
# Используйте домен вашего фронтенда
APP_URL=https://telegram-bots.pl

# Ключ шифрования для сессий телеграм бота (64 hex символа)
# Для генерации: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_ENCRYPTION_KEY=your_64_char_hex_encryption_key_here
