# Telegram Bot Token (получить через @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Backend API URL
# ⚠️ ВАЖНО: В production используйте HTTPS и ваш реальный домен!
# Пример для продакшена: https://telegram-bots-backend.onrender.com/api
BACKEND_API_URL=https://telegram-bots-backend.onrender.com/api

# Node environment (development или production)
NODE_ENV=development

# Режим работы бота (polling или webhook)
# polling - для Render.com free tier (рекомендуется)
# webhook - только если у вас есть выделенный порт
BOT_MODE=polling

# Webhook URL (только для BOT_MODE=webhook)
WEBHOOK_URL=https://your-bot-name.onrender.com/webhook

# Port для webhook сервера (только для BOT_MODE=webhook)
PORT=3000

# Ключ шифрования для сессий (64 hex символа)
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_ENCRYPTION_KEY=your_64_character_hex_encryption_key_here
