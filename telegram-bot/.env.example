# Telegram Bot Token (получить через @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Backend API URL
BACKEND_API_URL=http://localhost:3000/api

# Node environment (development или production)
NODE_ENV=development

# Режим работы бота (polling или webhook)
# polling - для Render.com free tier (рекомендуется)
# webhook - только если у вас есть выделенный порт
BOT_MODE=polling

# Webhook URL (только для BOT_MODE=webhook)
WEBHOOK_URL=https://your-bot-name.onrender.com/webhook

# Port для webhook сервера (только для BOT_MODE=webhook)
PORT=3000
