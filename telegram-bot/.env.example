# Telegram Bot Token (получить через @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Backend API URL
BACKEND_API_URL=http://localhost:3000/api

# Node environment (development или production)
NODE_ENV=development

# Webhook URL (для production на Render.com)
WEBHOOK_URL=https://your-bot-name.onrender.com/webhook

# Port для webhook сервера
PORT=3000
